{
  "name": "reel",
  "version": "0.1.0",
  "description": "Turn any page into a film you scrub by scrolling. A fixed full-bleed video background whose timeline is driven by scroll, plus scroll-pinned content reveals. Framework-agnostic core + React API.",
  "type": "module",
  "bin": {
    "reel": "./bin/reel.mjs"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist", "bin"],
  "sideEffects": ["*.css"],
  "scripts": {
    "build": "npm run build:ts && npm run build:css",
    "build:ts": "tsc",
    "build:css": "cp src/styles.css dist/styles.css",
    "dev": "tsc --watch"
  },
  "keywords": [
    "scroll",
    "scrollytelling",
    "video",
    "scrub",
    "background",
    "react",
    "animation",
    "film"
  ],
  "author": "Sayantan Bhowmik",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.0"
  }
}
