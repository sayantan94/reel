{
  "name": "reel-it",
  "version": "1.0.1",
  "description": "Turn any page into a film you scrub by scrolling. A fixed full-bleed video background whose timeline is driven by scroll, plus scroll-pinned content reveals. Framework-agnostic core + React API.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sayantan94/reel.git"
  },
  "homepage": "https://github.com/sayantan94/reel#readme",
  "bugs": {
    "url": "https://github.com/sayantan94/reel/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "reel": "bin/reel.mjs",
    "reel-it": "bin/reel.mjs"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "npm run build:ts && npm run build:css && npm run build:examples",
    "build:ts": "tsc",
    "build:css": "cp src/styles.css dist/styles.css",
    "build:examples": "cp dist/core.js examples/reel.core.js && cp dist/styles.css examples/reel.css",
    "dev": "tsc --watch",
    "pack:check": "npm run build && npm pack --dry-run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "scroll",
    "scrollytelling",
    "video",
    "scrub",
    "background",
    "react",
    "animation",
    "film"
  ],
  "author": "Sayantan Bhowmik",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.0"
  }
}
